  "keyFeatures": [
    "Motel search and discovery with interactive maps (Leaflet)",
    "Online room reservations with check-in/check-out date selection",
    "Stripe-powered secure payment processing",
    "Multi-role authentication: Admin, Owner, and Client",
    "Owner dashboard for managing motels, rooms, and offers",
    "Admin dashboard for platform oversight and motel approval workflows",
    "Geolocation support for finding nearby motels",
    "Progressive Web App (PWA) with mobile-first design",
    "Cloudinary integration for motel and room image management",
    "Server-Side Rendering (SSR) with Angular Universal"
  ],
  "publicApiSurface": [
    "GET /api/motels — List all approved motels",
    "GET /api/motels/:id — Get motel details",
    "POST /api/motels — Create a new motel (owner)",
    "PUT /api/motels/:id — Update motel info (owner)",
    "DELETE /api/motels/:id — Delete a motel (owner)",
    "GET /api/auth/motels/my-motels — Get owner's motels",
    "GET /api/rooms — List rooms for a motel",
    "POST /api/rooms — Create a room (owner)",
    "POST /api/reservations — Create a reservation",
    "POST /api/payments/create-intent — Create Stripe payment intent",
    "GET /api/payments/config — Get Stripe publishable key",
    "GET /auth/me — Get current authenticated user",
    "POST /auth/login — Authenticate user",
    "POST /auth/register — Register new user",
    "POST /api/images/upload — Upload image to Cloudinary"
  ]
